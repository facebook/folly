fb_dirsync_cpp_library(
    name = "static_singleton_manager",
    srcs = ["StaticSingletonManager.cpp"],
    headers = ["StaticSingletonManager.h"],
    force_static = select({
        "DEFAULT": select({
            "DEFAULT": None,
            "ovr_config//os:macos": True,
        }),
        # ARVR builds (e.g. VrDriver) don't benefit from dynamic linking of
        # static_singleton_manager and it adds ~128KB to the APK size. Force
        # static linking for ARVR mode to avoid the extra .so overhead.
        "ovr_config//build_mode:arvr_mode": True,
    }),
    use_raw_headers = True,
    deps = [
        "//folly/memory:reentrant_allocator",
    ],
    exported_deps = [
        ":singleton",
        "//folly:c_portability",
        "//folly:indestructible",
        "//folly:likely",
        "//folly:utility",
        "//folly/lang:thunk",
        "//folly/lang:type_info",
    ],
)

fb_dirsync_cpp_library(
    name = "traponavx512",
