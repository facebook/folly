<#
GitHub Actions workflow template for `getdeps.py generate-github-actions`.
Jinja delimiters here are doubled angle brackets (variables) and angle-percent
(statements) so GitHub Actions dollar-double-brace expressions are literal.
The Jinja env is configured trim_blocks + lstrip_blocks, so block tags on
their own line consume the whole line cleanly without `-` stripping markers.
#>
<% macro cache_restore(name) %>
    - name: Restore <<name>> from cache
      id: restore_<<name>>
      if: ${{ steps.paths.outputs.<<name>>_SOURCE }}
      uses: actions/cache/restore@v4
      with:
       path: ${{ steps.paths.outputs.<<name>>_INSTALL }}
       key: ${{ steps.paths.outputs.<<name>>_CACHE_KEY }}-install
<%- endmacro %>

<% macro cache_save(name) %>
    - name: Save <<name>> to cache
      uses: actions/cache/save@v4
      if: ${{ steps.paths.outputs.<<name>>_SOURCE && ! steps.restore_<<name>>.outputs.cache-hit }}
      with:
       path: ${{ steps.paths.outputs.<<name>>_INSTALL }}
       key: ${{ steps.paths.outputs.<<name>>_CACHE_KEY }}-install
<%- endmacro %>

# This file was <<"@" + "generated">> by getdeps.py

name: <<job_name>>

on:<<run_on_block>>

permissions:
  contents: read  #  to fetch code (actions/checkout)
  actions: read  #  to query GitHub Actions cache usage

jobs:
  build:
    runs-on: <<runs_on>>
    timeout-minutes: <<timeout_minutes>>
<% if env_lines %>
    env:
<% for line in env_lines %>
      <<line>>
<% endfor %>
<% endif %>
    steps:

    <# Runner info banner #>
<% if is_linux %>
    - name: Show runner info
      run: |
        echo "CPU cores: $(nproc)"
        cat /proc/cpuinfo | grep 'model name' | head -1
        free -h
<% elif is_darwin %>
    - name: Show runner info
      run: |
        echo "CPU cores: $(sysctl -n hw.ncpu)"
        sysctl -n machdep.cpu.brand_string
        sysctl -n hw.memsize | awk '{print "Memory: " $1/1073741824 " GB"}'
<% elif is_windows %>
    - name: Show runner info
      run: |
        echo "CPU cores: $env:NUMBER_OF_PROCESSORS"
        (Get-CimInstance Win32_Processor).Name
        [math]::Round((Get-CimInstance Win32_ComputerSystem).TotalPhysicalMemory / 1GB, 1).ToString() + " GB RAM"
      shell: pwsh
<% endif %>

<% if is_windows %>
    <# Windows-only environment fixups #>
    - name: Export boost environment
      run: "echo BOOST_ROOT=%BOOST_ROOT_1_83_0% >> %GITHUB_ENV%"
      shell: cmd

    - name: Fix Git config
      run: >
        git config --system core.longpaths true &&
        git config --system core.autocrlf false &&
        git config --system core.symlinks true
      shell: cmd
<% endif %>

    - uses: actions/checkout@v6

<% if use_sccache %>
    - name: Set up sccache
      uses: mozilla-actions/sccache-action@v0.0.9
      with:
        version: "v0.14.0"
<% endif %>

<% if free_up_disk and not is_windows %>
    <# Pre-build disk cleanup (linux/darwin only) #>
    - name: Show disk space at start
      run: df -h
    - name: Free up disk space
      run: sudo rm -rf /usr/local/lib/android
    - name: Show disk space after freeing up
      run: df -h
<% endif %>

<% if system_deps %>
    <# System dependency install via the host package manager #>
<% if system_deps.apt_update_cmd %>
    - name: Update system package info
      run: <<system_deps.apt_update_cmd>>
<% endif %>
    - name: Install system deps
      run: <<system_deps.install_cmd>>
<% if system_deps.locales %>
    - name: Install locale-gen
      run: <<system_deps.locale_install_cmd>>
<% for loc in system_deps.locales %>
    - name: Ensure <<loc>> locale present
      run: <<system_deps.locale_gen_prefix>><<loc>>
<% endfor %>
<% endif %>
<% endif %>

    <# Resolve install/source/cache paths for every dep #>
    - id: paths
      name: Query paths
      run: <<query_paths_cmd>>
<% if is_windows %>
      shell: pwsh
<% endif %>

<% if rust_version %>
    - name: Install Rust <<rust_version_cap>>
      uses: dtolnay/rust-toolchain@<<rust_version>>
<% endif %>

<% if same_repo_fetches %>
    <# Pre-fetch deps that live in different repos #>
<% for name in same_repo_fetches %>
    - name: Fetch <<name>>
      if: ${{ steps.paths.outputs.<<name>>_SOURCE }}
      run: <<fetch_cmd_prefix>><<name>>
<% endfor %>
<% endif %>

    <# Per-dep build (with optional cache restore + save) #>
<% for dep in deps %>
<% if dep.use_cache %>
<<cache_restore(dep.name)>>
<% endif %>
    - name: Build <<dep.name>>
<% if dep.if_clause %>
      if: ${{ <<dep.if_clause>> }}
<% endif %>
      run: <<dep.build_cmd>>
<% if dep.use_cache %>
<<cache_save(dep.name)>>
<% endif %>

<% endfor %>
<% if free_up_disk_before_build and not is_windows %>
    - name: Free up disk space before build
      run: |
        sudo rm -rf /usr/share/dotnet /usr/local/share/powershell /opt/ghc /usr/local/.ghcup
        df -h

<% endif %>
    <# Final build of the leaf project #>
    - name: Build <<project_name>>
      run: <<final_build_cmd>>

<% if use_sccache %>
    - name: Show sccache stats
      if: always()
      run: sccache --show-stats
<% endif %>

    <# Artifact collection + upload #>
    - name: Copy artifacts
      run: <<copy_artifacts_cmd>>
    - uses: actions/upload-artifact@v6
      with:
        name: <<project_name>>
        path: _artifacts

<% if test_cmd %>
    - name: Test <<project_name>>
      run: <<test_cmd>>
<% endif %>

<% if free_up_disk and not is_windows %>
    - name: Show disk space at end
      if: always()
      run: df -h
<% endif %>

    - name: Show GitHub Actions cache usage
      if: always()
      env:
        GH_TOKEN: ${{ github.token }}
      run: gh cache list --repo ${{ github.repository }} --sort size_in_bytes --order desc --limit 30
